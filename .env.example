# === BSA Kit Environment Variables ===

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"

# AI Providers
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="AIza..."

# MCP Connections
FIGMA_PERSONAL_ACCESS_TOKEN=""
CONFLUENCE_BASE_URL=""
CONFLUENCE_USERNAME=""
CONFLUENCE_API_TOKEN=""

# SePay Payment Gateway (Vietnamese Bank Transfer)
SEPAY_BASE_URL="https://pgapi-sandbox.sepay.vn"
SEPAY_MERCHANT_ID=""
SEPAY_SECRET_KEY=""

# App
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000

# Security
ENCRYPTION_KEY=""  # 32-byte hex for credential encryption
