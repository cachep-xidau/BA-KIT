{
    "name": "bsa-kit",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "type-check": "turbo run type-check",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "clean": "turbo run clean && rm -rf node_modules"
    },
    "devDependencies": {
        "next": "^15.1.0",
        "turbo": "^2.4.0",
        "prettier": "^3.4.0",
        "typescript": "^5.7.0"
    },
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=20"
    }
}